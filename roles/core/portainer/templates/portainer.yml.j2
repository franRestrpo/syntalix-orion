version: "3.7"
services:

  agent:
    image: portainer/agent:latest
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /var/lib/docker/volumes:/var/lib/docker/volumes
    networks:
      - {{ app_actual.internal_network | default('SyntalixNet', true) }}
    deploy:
      mode: global
      placement:
        constraints: [node.platform.os == linux]

  portainer:
    image: portainer/portainer-ce:latest
    command: -H tcp://tasks.agent:9001 --tlsskipverify --encryption-key-file=/run/secrets/portainer
    volumes:
      - portainer_data:/data
      - {{ playbook_dir }}/deploy/portainer_encryption.key:/run/secrets/portainer:ro
    networks:
      - {{ app_actual.internal_network | default('SyntalixNet', true) }}
    deploy:
      mode: replicated
      replicas: 1
      placement:
        constraints: [node.role == manager]
      labels:
        - "traefik.enable=true"
        - "traefik.docker.network={{ app_actual.internal_network | default('SyntalixNet', true) }}"
        - "traefik.http.routers.portainer.rule=Host(`{{ app_actual.dominio }}`)"
        - "traefik.http.services.portainer.loadbalancer.server.port=9000"
        - "traefik.http.routers.portainer.tls.certresolver=letsencryptresolver"
        - "traefik.http.routers.portainer.service=portainer"
        - "traefik.http.routers.portainer.entrypoints=websecure"
        - "traefik.http.routers.portainer.priority=1"

volumes:
  portainer_data:
    external: true
    name: portainer_data

networks:
  {{ app_actual.internal_network | default('SyntalixNet', true) }}:
    external: true
    attachable: true
    name: {{ app_actual.internal_network | default('SyntalixNet', true) }}
