# Chatwoot Environment Config
FRONTEND_URL=https://{{ app_actual.dominio }}
SECRET_KEY_BASE={{ chatwoot_secret_key_base | default('32bit_random_string_if_lookup_fails', true) }}
NODE_ENV=production
RAILS_ENV=production
INSTALLATION_ENV=docker

# Database
POSTGRES_HOST={{ app_actual.nombre }}_postgres
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD={{ POSTGRES_PGVECTOR__POSTGRES_PASSWORD | default('chatwoot123', true) }}
POSTGRES_DATABASE=chatwoot

# Redis
REDIS_URL=redis://{{ app_actual.nombre }}_redis:6379

# Email (Placeholder)
MAILER_SENDER_EMAIL=noreply@{{ app_actual.dominio }}
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user
SMTP_PASSWORD=pass
