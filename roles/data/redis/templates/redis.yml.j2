version: '3.8'
services:
  redis:
    image: redis:7-alpine
    command: redis-server --requirepass {{ REDIS__REDIS_PASSWORD | default('secret', true) }}
    deploy:
      restart_policy:
        condition: on-failure
    environment:
      - REDIS_PASSWORD={{ REDIS__REDIS_PASSWORD | default('secret', true) }}
    networks:
      SyntalixNet:
        aliases:
          - redis-cache
    volumes:
      - redis_data:/data

networks:
  SyntalixNet:
    external: true

volumes:
  redis_data:
