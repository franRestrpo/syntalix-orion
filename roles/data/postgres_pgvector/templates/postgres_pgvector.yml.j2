version: '3.8'
services:
  postgres:
    image: pgvector/pgvector:pg16
    deploy:
      restart_policy:
        condition: on-failure
    environment:
      - POSTGRES_USER={{ POSTGRES_PGVECTOR__POSTGRES_USER | default('orion_admin', true) }}
      - POSTGRES_PASSWORD={{ app_actual.password_db | default(POSTGRES_PGVECTOR__POSTGRES_PASSWORD | default('secret', true)) }}
      - POSTGRES_DB={{ POSTGRES_PGVECTOR__POSTGRES_DB | default('appdb', true) }}
    networks:
      SyntalixNet:
        aliases:
          - postgres-db
    volumes:
      - postgres_data:/var/lib/postgresql/data

networks:
  SyntalixNet:
    external: true

volumes:
  postgres_data:
