version: '3.8'

services:
  app:
    image: diouxx/glpi
    env_file:
      - {{ playbook_dir }}/secrets/glpi.env
    networks:
      - {{ docker_network_name | default('SyntalixNet') }}
    deploy:
      labels:
        - "traefik.enable=true"
        - "traefik.http.routers.glpi.rule=Host(`{{ GLPI__DOMAIN | default('glpi.localhost') }}`)"
        - "traefik.http.services.glpi.loadbalancer.server.port=80"

networks:
  {{ docker_network_name | default('SyntalixNet') }}:
    external: true
